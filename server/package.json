{
  "name": "server",
  "version": "4.0.0",
  "main": "server.js",
  "license": "MIT",
  "scripts": {
    "pretypes": "gql-merge --out-file ./src/schema.graphql ./src/api/**/*.graphql",
    "types": "graphql-to-typescript ./src/schema.graphql ./src/types/graph.d.ts",
    "prestart": "yarn types",
    "start": "NODE_ENV=development ts-node-dev --respawn ./src/server.ts",
    "build": "npx tsc",
    "production": "NODE_ENV=production node dist/server.js"
  },
  "dependencies": {
    "@koa/cors": "^3.1.0",
    "aligoapi": "^1.1.2",
    "apollo-server-koa": "^2.19.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^8.2.0",
    "gql-merge": "^0.0.6",
    "graphql": "^15.4.0",
    "graphql-middleware": "^4.0.2",
    "graphql-tools": "^7.0.1",
    "jsonwebtoken": "^8.5.1",
    "koa": "^2.13.0",
    "koa-body": "^4.2.0",
    "koa-router": "^10.0.0",
    "koa-send": "^5.0.1",
    "koa-static": "^5.0.0",
    "merge-graphql-schemas": "^1.7.8",
    "pg": "^8.3.0",
    "typeorm": "^0.2.25"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.2",
    "@types/dotenv": "^8.2.0",
    "@types/jsonwebtoken": "^8.5.0",
    "@types/koa": "^2.11.6",
    "@types/koa-router": "^7.4.1",
    "@types/koa-send": "^4.1.2",
    "@types/koa-static": "^4.0.1",
    "@types/node": "^14.14.9",
    "babel-runtime": "^6.26.0",
    "graphql-to-typescript": "^0.1.2",
    "ts-node-dev": "^1.0.0",
    "typescript": "^4.1.2"
  }
}
